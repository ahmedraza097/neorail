# Copy this file to .env and fill in your values
# cp .env.example .env

# MongoDB connection string
# Option 1 - Local MongoDB (install MongoDB on your machine first)
MONGO_URI=mongodb://localhost:27017/train_ticket

# Option 2 - MongoDB Atlas (free cloud database)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/train_ticket

# Server port (optional, defaults to 3000)
PORT=3000
